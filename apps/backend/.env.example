# ──────────────────────────────────────────────
# EVCore Backend — Environment Variables Template
# Copy to .env and fill in real values.
# Never commit .env — only .env.example.
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/evcore

# ── Redis (BullMQ) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API-FOOTBALL (api-football.com / v3.football.api-sports.io) ──
# Single key for fixtures, results, and future pre-match odds (Phase 2).
# Plan Pro ($19/mo) recommended for MVP.
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_LEAGUE_ID=39
API_FOOTBALL_PLAN=pro
API_FOOTBALL_QUOTA_ALERT_PCT=80
API_FOOTBALL_DAILY_QUOTA=7500
# Capacity assumptions for quota planning logs at bootstrap
API_FOOTBALL_AVG_DAILY_FIXTURES_PER_LEAGUE=10
API_FOOTBALL_AVG_DAILY_STATS_FIXTURES_PER_LEAGUE=4

# ── SMTP (nodemailer) ─────────────────────────────────────────────────────────
# Set SMTP_ENABLED=true to activate email alerts.
# In local dev: use Mailpit (docker-compose) — no real emails sent.
# In production: replace with your SMTP provider (Gmail, Amazon SES, etc.)
SMTP_ENABLED=false

# Local dev (Mailpit): host=localhost, port=1025, no auth
# Production (Gmail):  host=smtp.gmail.com, port=587, secure=false + app password
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false

# Leave empty for Mailpit (no auth). Fill in for real SMTP providers.
SMTP_USER=
SMTP_PASSWORD=

SMTP_FROM=evcore@localhost
# Single recipient for all alerts (you / your team).
SMTP_TO=admin@example.com

# ── ETL scheduling ────────────────────────────────
# Set to "false" to disable BullMQ repeatable jobs (useful in dev/test)
ETL_SCHEDULING_ENABLED=true

# Odds snapshot maintenance (fallback default if no manual override in ETL job body)
ODDS_SNAPSHOT_RETENTION_DAYS=30
