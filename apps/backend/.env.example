# ------------------------------------------------------------
# Backend runtime
# ------------------------------------------------------------
# Optional (default: 3000)
PORT=3000
# Optional (default: 0.0.0.0)
HOST=0.0.0.0

# ------------------------------------------------------------
# Infrastructure
# ------------------------------------------------------------
# Required for Prisma (PostgreSQL connection string)
DATABASE_URL=
# Optional for BullMQ (defaults used in AppModule if omitted)
REDIS_HOST=localhost
REDIS_PORT=6379

# ------------------------------------------------------------
# ETL providers
# ------------------------------------------------------------
# Required for football-data.org workers (fixtures/results) (https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=

# Required for API-Sports odds worker (https://www.api-football.com/)
ODDS_API_KEY=
# Optional (default: 39 = EPL)
ODDS_API_LEAGUE_ID=39

# ------------------------------------------------------------
# Novu (notifications)
# ------------------------------------------------------------
# Optional URL if self-hosted/local Novu
NOVU_API_URL=http://localhost:3010
# Required only when triggering Novu notifications
NOVU_API_KEY=
# Optional (default used in code)
NOVU_WORKFLOW_ID=evcore-foundations-notification
# Optional for test endpoint/notifications
NOVU_TEST_SUBSCRIBER_ID=evcore-admin
NOVU_TEST_EMAIL=
