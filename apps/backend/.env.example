# ──────────────────────────────────────────────
# EVCore Backend — Environment Variables Template
# Copy to .env and fill in real values.
# Never commit .env — only .env.example.
# ──────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3000

# ── Database ──────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/evcore

# ── Redis (BullMQ) ────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── API-FOOTBALL (api-football.com / v3.football.api-sports.io) ──
# Single key for fixtures, results, and future pre-match odds (Phase 2).
# Plan Pro ($19/mo) recommended for MVP.
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_LEAGUE_ID=39
API_FOOTBALL_PLAN=pro
API_FOOTBALL_QUOTA_ALERT_PCT=80

# ── Novu (notifications) ──────────────────────
NOVU_API_URL=http://localhost:3010
NOVU_API_KEY=your_novu_api_key_here
# Legacy workflow used by app health check
NOVU_WORKFLOW_ID=evcore-foundations-notification
NOVU_TEST_SUBSCRIBER_ID=evcore-admin
NOVU_TEST_EMAIL=admin@example.com
# Subscriber ID used by NotificationService (defaults to evcore-admin)
NOVU_SUBSCRIBER_ID=evcore-admin
# Set to "false" to disable all Novu alerts globally (e.g. in test environments)
NOVU_ALERTS_ENABLED=true

# ── Novu Workflow IDs (create these in Novu dashboard) ───────────
# Workflow: ROI below -10% alert → evcore-roi-alert
# Workflow: Market auto-suspended → evcore-market-suspension
# Workflow: Brier score above threshold → evcore-brier-alert
# Workflow: Weekly ROI/Brier report → evcore-weekly-report
