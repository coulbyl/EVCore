{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "builder": "swc",
    "typeCheck": true,
    "deleteOutDir": true,
    "assets": [
      {
        "include": "../../packages/db/src/generated/prisma/**/*",
        "outDir": "dist/src/generated/prisma"
      }
    ],
    "watchAssets": true
  }
}
