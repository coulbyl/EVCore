{
  "name": "@evcore/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:stats": "tsx scripts/db-stats.ts",
    "db:purge:analysis": "tsx scripts/purge-analysis-data.ts",
    "db:cleanup:legacy-ml-models": "tsx scripts/cleanup-legacy-ml-models.ts",
    "db:scheduled": "tsx scripts/scheduled-fixtures-report.ts",
    "db:audit:fixtures": "tsx scripts/audit-fixtures.ts",
    "db:audit:fri-goals": "tsx scripts/fri-goal-model-audit.ts",
    "db:audit:fri-xg": "tsx scripts/fri-xg-audit.ts",
    "db:audit:fri-elo": "tsx scripts/fri-elo-audit.ts",
    "db:analyze:signals": "tsx scripts/analyze-signals.ts",
    "db:analyze:edge": "tsx scripts/analyze-edge.ts",
    "db:backtest:ev-tiers": "tsx scripts/backtest-ev-tiers.ts",
    "db:backtest:new-markets-calibration": "tsx scripts/backtest-new-markets-calibration.ts",
    "db:backtest:home-advantage": "tsx scripts/backtest-home-advantage-calibration.ts",
    "db:backtest:home-advantage-roi": "tsx scripts/backtest-home-advantage-roi-impact.ts",
    "db:backtest:h2h-signal-value": "tsx scripts/backtest-h2h-signal-value.ts",
    "db:backtest:h2h-brier-gain": "tsx scripts/backtest-h2h-brier-gain.ts",
    "db:backtest:h2h-lambda-all-markets": "tsx scripts/backtest-h2h-lambda-adjustment-all-markets.ts",
    "db:backtest:h2h-venue-weighting": "tsx scripts/backtest-h2h-venue-weighting.ts",
    "db:backtest:h2h-market-signals": "tsx scripts/backtest-h2h-market-signals.ts",
    "db:backtest:invest-ranking": "tsx scripts/backtest-invest-ranking.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@evcore/analysis-core": "workspace:*",
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:",
    "prisma": "catalog:"
  },
  "devDependencies": {
    "@evcore/eslint-config": "workspace:*",
    "@evcore/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "tsx": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:"
  }
}
