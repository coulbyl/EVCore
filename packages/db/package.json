{
  "name": "@evcore/db",
  "version": "0.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:stats": "tsx scripts/db-stats.ts",
    "db:audit:sa-away": "tsx scripts/sa-away-audit.ts",
    "db:reset-zero-xg": "tsx scripts/reset-zero-xg.ts",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/adapter-pg": "catalog:",
    "@prisma/client": "catalog:"
  },
  "devDependencies": {
    "@evcore/eslint-config": "workspace:*",
    "@evcore/typescript-config": "workspace:*",
    "@types/node": "catalog:",
    "dotenv": "catalog:",
    "tsx": "catalog:",
    "eslint": "catalog:",
    "prisma": "catalog:",
    "typescript": "catalog:"
  }
}
