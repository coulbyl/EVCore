// EVCore — Prisma Schema
// See EVCORE.md section 3.4 for table descriptions
// See CLAUDE.md for repository conventions

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum FixtureStatus {
  SCHEDULED
  IN_PROGRESS
  FINISHED
  POSTPONED
  CANCELLED
}

enum ModelRunPhase {
  ADVANCE
  PRE_KICKOFF
  LIVE
}

enum Market {
  ONE_X_TWO
  OVER_UNDER
  BTTS
  DOUBLE_CHANCE
  HALF_TIME_FULL_TIME
  OVER_UNDER_HT
  FIRST_HALF_WINNER
}

enum BetStatus {
  PENDING
  WON
  LOST
  VOID
}

enum BetSource {
  MODEL
  USER
}

enum BetSlipType {
  SIMPLE
  COMBO
}

enum BankrollTransactionType {
  DEPOSIT
  BET_PLACED
  BET_WON
  BET_VOID
}

enum UserRole {
  ADMIN
  OPERATOR
}

enum UnitMode {
  FIXED
  PCT
}

enum FormationContentType {
  ARTICLE
  VIDEO
}

enum AdjustmentStatus {
  PENDING
  APPLIED
  REJECTED
  FROZEN
}

enum OddsSnapshotSource {
  PREMATCH
  HISTORICAL
}

enum NotificationType {
  ROI_ALERT
  MARKET_SUSPENSION
  BRIER_ALERT
  WEEKLY_REPORT
  ETL_FAILURE
  WEIGHT_ADJUSTMENT
  XG_UNAVAILABLE_REPORT
  ML_MODEL_ACTIVATED
}

enum MfaMethod {
  EMAIL
  TOTP
}

enum SportType {
  FOOTBALL
}

enum StrategyChannel {
  VALUE
  SAFE
  DOMINANT
  BTTS
  DRAW
  GOALS
  FIRST_HALF
  DOUBLE_CHANCE
  UNDERDOG
  FAVORITE
  LIVE_VALUE
  MARKET_MOVE
  CONSENSUS
  CONTRARIAN
  AVOID
}

enum ChannelDecisionStatus {
  SELECTED
  REJECTED
  DISABLED
  INSUFFICIENT_DATA
  MISSING_ODDS
  NOT_APPLICABLE
}

enum CouponProposalStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED

  @@map("coupon_proposal_status")
}

enum CouponResult {
  WON
  LOST
  PARTIAL
  VOID

  @@map("coupon_result")
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model Competition {
  id                String     @id @default(dbgenerated("uuidv7()")) @db.Uuid
  leagueId          Int        @unique
  code              String     @unique
  name              String
  country           String
  sport             SportType  @default(FOOTBALL)
  isActive          Boolean
  includeInBacktest Boolean    @default(true)
  csvDivisionCode   String?
  seasonStartMonth  Int?
  apiSeasonOverride Int?
  seasons           Season[]
  teams             Team[]
  standings         Standing[]
  createdAt         DateTime   @default(now())

  @@map("competition")
}

model Season {
  id            String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  competitionId String      @db.Uuid
  competition   Competition @relation(fields: [competitionId], references: [id])
  name          String // e.g. "2022-23"
  startDate     DateTime
  endDate       DateTime
  fixtures      Fixture[]
  standings     Standing[]
  createdAt     DateTime    @default(now())

  @@unique([competitionId, name])
  @@map("season")
}

model Standing {
  id            String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  competitionId String      @db.Uuid
  seasonId      String      @db.Uuid
  competition   Competition @relation(fields: [competitionId], references: [id])
  season        Season      @relation(fields: [seasonId], references: [id])
  teamApiId     Int
  teamName      String
  teamLogo      String
  group         String
  rank          Int
  points        Int
  played        Int
  win           Int
  draw          Int
  lose          Int
  goalsFor      Int
  goalsAgainst  Int
  goalsDiff     Int
  form          String?
  description   String?
  syncedAt      DateTime    @updatedAt

  @@unique([competitionId, seasonId, teamApiId])
  @@map("standing")
}

model Team {
  id            String      @id @default(dbgenerated("uuidv7()")) @db.Uuid
  externalId    Int         @unique // football-data.org ID
  name          String
  shortName     String
  logoUrl       String?
  competitionId String      @db.Uuid
  competition   Competition @relation(fields: [competitionId], references: [id])
  homeFixtures  Fixture[]   @relation("HomeTeam")
  awayFixtures  Fixture[]   @relation("AwayTeam")
  stats         TeamStats[]
  createdAt     DateTime    @default(now())

  @@map("team")
}

model Fixture {
  id                 String              @id @default(dbgenerated("uuidv7()")) @db.Uuid
  externalId         Int                 @unique // football-data.org ID
  seasonId           String              @db.Uuid
  season             Season              @relation(fields: [seasonId], references: [id])
  homeTeamId         String              @db.Uuid
  homeTeam           Team                @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId         String              @db.Uuid
  awayTeam           Team                @relation("AwayTeam", fields: [awayTeamId], references: [id])
  matchday           Int
  round              String? // raw API round string (e.g. "Quarter-finals", "League Stage - 1")
  leg                Int? // 1 = aller, 2 = retour — null for group/league stage
  aggregateHomeGoals Int? // goals scored by home team's side in leg 1 (set on leg 2 only)
  aggregateAwayGoals Int? // goals scored by away team's side in leg 1 (set on leg 2 only)
  scheduledAt        DateTime
  status             FixtureStatus       @default(SCHEDULED)
  homeScore          Int?
  awayScore          Int?
  homeHtScore        Int?
  awayHtScore        Int?
  homeXg             Decimal?            @db.Decimal(5, 3) // from API-Football expected_goals
  awayXg             Decimal?            @db.Decimal(5, 3) // from API-Football expected_goals
  xgUnavailable      Boolean             @default(false) // true = API returned no stats, skip on retry
  modelRuns          ModelRun[]
  bets               Bet[]
  betSlipItems       BetSlipItem[]
  teamStats          TeamStats[]
  oddsSnapshots      OddsSnapshot[]
  couponLegs         CouponProposalLeg[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([seasonId, matchday])
  @@index([seasonId, round])
  @@index([scheduledAt])
  @@index([status, scheduledAt])
  @@index([seasonId, status, scheduledAt])
  @@index([homeTeamId, status, scheduledAt])
  @@index([awayTeamId, status, scheduledAt])
  @@map("fixture")
}

// Rolling stats computed for a team after a given fixture was played.
// One row per team per fixture (home team stats + away team stats).
model TeamStats {
  id             String  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  teamId         String  @db.Uuid
  team           Team    @relation(fields: [teamId], references: [id])
  afterFixtureId String  @db.Uuid
  afterFixture   Fixture @relation(fields: [afterFixtureId], references: [id])

  // Feature values used in the deterministic scoring model (see EVCORE.md §4.1)
  recentForm       Decimal @db.Decimal(5, 4) // weighted 5-match form (decay 0.8)
  xgFor            Decimal @db.Decimal(5, 3) // rolling xG scored (10 matches)
  xgAgainst        Decimal @db.Decimal(5, 3) // rolling xG conceded (10 matches)
  homeWinRate      Decimal @db.Decimal(5, 4) // season home win rate
  awayWinRate      Decimal @db.Decimal(5, 4) // season away win rate
  drawRate         Decimal @db.Decimal(5, 4) // season draw rate
  leagueVolatility Decimal @db.Decimal(5, 4) // std-dev of total goals in league

  createdAt DateTime @default(now())

  @@unique([teamId, afterFixtureId])
  @@map("team_stats")
}

// Output of one betting engine analysis for a fixture.
model ModelRun {
  id         String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  fixtureId  String        @db.Uuid
  fixture    Fixture       @relation(fields: [fixtureId], references: [id])
  analyzedAt DateTime      @default(now())
  phase      ModelRunPhase @default(PRE_KICKOFF)

  deterministicScore Decimal  @db.Decimal(5, 4)
  llmDelta           Decimal? @db.Decimal(5, 4) // null in MVP (OpenClaw not active)
  finalScore         Decimal  @db.Decimal(5, 4)

  // Snapshot of feature values at analysis time — enables ModelRun replay
  features    Json // { recentForm, xg, performanceDomExt, volatiliteLigue }
  openclawRaw Json? // raw LLM output — null in MVP

  validatedByBackend Boolean           @default(false)
  bets               Bet[]
  channelDecisions   ChannelDecision[]
  createdAt          DateTime          @default(now())

  @@index([fixtureId])
  @@index([fixtureId, analyzedAt])
  @@index([analyzedAt])
  @@index([phase, analyzedAt])
  @@map("model_run")
}

// One bet per market per ModelRun.
model Bet {
  id                   String                @id @default(dbgenerated("uuidv7()")) @db.Uuid
  modelRunId           String                @db.Uuid
  modelRun             ModelRun              @relation(fields: [modelRunId], references: [id])
  fixtureId            String                @db.Uuid
  fixture              Fixture               @relation(fields: [fixtureId], references: [id])
  market               Market
  pick                 String // HOME | DRAW | AWAY | OVER | UNDER | YES | NO | 1X | X2 | 12
  pickKey              String // canonical key: "<market>|<pick>|<comboMarket?>|<comboPick?>"
  probEstimated        Decimal               @db.Decimal(5, 4)
  oddsSnapshot         Decimal?              @db.Decimal(6, 3) // null in MVP phase 1 (no prematch odds)
  ev                   Decimal               @db.Decimal(6, 4) // EV = (probEstimated * oddsSnapshot) - 1
  qualityScore         Decimal?              @db.Decimal(6, 4) // ev × deterministicScore — used for pick pool ranking (null for legacy bets)
  stakePct             Decimal               @db.Decimal(5, 4) // 0.01 = 1% bankroll
  status               BetStatus             @default(PENDING)
  // combo-match fields: null for single-market picks
  comboMarket          Market?
  comboPick            String? // secondary pick (e.g. "YES", "OVER")
  // source: MODEL for engine bets, USER for user-placed picks from evaluated picks
  source               BetSource             @default(MODEL)
  userId               String?               @db.Uuid
  user                 User?                 @relation(fields: [userId], references: [id])
  // link to the ChannelSelection that generated this bet (null for legacy bets)
  channelSelectionId   String?               @db.Uuid
  channelSelection     ChannelSelection?     @relation(fields: [channelSelectionId], references: [id])
  betSlipItems         BetSlipItem[]
  bankrollTransactions BankrollTransaction[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  @@unique([fixtureId, pickKey, userId])
  @@index([modelRunId])
  @@index([fixtureId])
  @@index([market, status, createdAt])
  @@index([status, updatedAt])
  @@index([userId])
  @@map("bet")
}

model User {
  id                   String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  email                String                  @unique
  username             String                  @unique
  passwordHash         String
  fullName             String
  bio                  String?
  role                 UserRole                @default(OPERATOR)
  emailVerified        Boolean                 @default(false)
  mfaMethod            MfaMethod?
  totpSecret           String?
  totpVerified         Boolean                 @default(false)
  avatarUrl            String?
  theme                String?
  locale               String?
  currency             String?
  unitMode             UnitMode?
  unitAmount           Decimal?                @db.Decimal(12, 2)
  unitPercent          Decimal?                @db.Decimal(5, 4)
  sessions             Session[]
  betSlips             BetSlip[]
  betSlipItems         BetSlipItem[]
  bets                 Bet[]
  bankrollTransactions BankrollTransaction[]
  contentProgress      UserContentProgress[]
  announcements        Announcement[]
  badges               UserBadge[]
  notificationReads    UserNotificationRead[]
  verificationCodes    EmailVerificationCode[]
  resetTokens          PasswordResetToken[]
  chatConversations    ChatConversation[]
  chatUsage            ChatUsage[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  @@map("users")
}

model EmailVerificationCode {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([userId, expiresAt])
  @@map("email_verification_code")
}

model PasswordResetToken {
  id               String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId           String   @db.Uuid
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash        String   @unique
  expiresAt        DateTime
  used             Boolean  @default(false)
  isAdminGenerated Boolean  @default(false)
  createdAt        DateTime @default(now())

  @@index([userId])
  @@map("password_reset_token")
}

model Announcement {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  title       String
  description String
  href        String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  expiresAt   DateTime?
  createdById String?   @db.Uuid
  createdBy   User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@index([createdAt])
  @@map("announcement")
}

model UserContentProgress {
  id          String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId      String               @db.Uuid
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentType FormationContentType
  slug        String
  completedAt DateTime
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@unique([userId, contentType, slug])
  @@index([userId])
  @@index([completedAt])
  @@map("user_content_progress")
}

model Session {
  id        String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, expiresAt])
  @@map("user_session")
}

model BetSlip {
  id        String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  unitStake Decimal       @db.Decimal(12, 2)
  type      BetSlipType   @default(SIMPLE)
  items     BetSlipItem[]
  createdAt DateTime      @default(now())

  @@index([userId, createdAt])
  @@map("bet_slip")
}

model BetSlipItem {
  betSlipId     String   @db.Uuid
  betSlip       BetSlip  @relation(fields: [betSlipId], references: [id], onDelete: Cascade)
  userId        String   @db.Uuid
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  betId         String   @db.Uuid
  bet           Bet      @relation(fields: [betId], references: [id], onDelete: Cascade)
  fixtureId     String   @db.Uuid
  fixture       Fixture  @relation(fields: [fixtureId], references: [id], onDelete: Cascade)
  stakeOverride Decimal? @db.Decimal(12, 2)
  createdAt     DateTime @default(now())

  @@id([betSlipId, betId])
  @@unique([betSlipId, fixtureId])
  @@index([betId])
  @@index([fixtureId])
  @@map("bet_slip_item")
}

model BankrollTransaction {
  id        String                  @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId    String                  @db.Uuid
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      BankrollTransactionType
  amount    Decimal                 @db.Decimal(14, 2)
  betId     String?                 @db.Uuid
  bet       Bet?                    @relation(fields: [betId], references: [id])
  note      String?
  createdAt DateTime                @default(now())

  @@index([userId, createdAt])
  @@map("bankroll_transaction")
}

// Proposed weight adjustments from the learning loop.
// Backend decides whether to apply, reject, or freeze (never auto-applied).
model AdjustmentProposal {
  id               String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  triggerBetCount  Int // number of bets that triggered this proposal
  currentWeights   Json // { recentForm: 0.30, xg: 0.30, ... }
  proposedWeights  Json // { recentForm: 0.32, xg: 0.28, ... }
  calibrationError Decimal          @db.Decimal(6, 5)
  status           AdjustmentStatus @default(PENDING)
  appliedAt        DateTime?
  reviewedBy       String?
  notes            String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, appliedAt])
  @@index([createdAt])
  @@map("adjustment_proposal")
}

// Active suspension of a market triggered automatically by risk rules.
// Only one active suspension per market at a time (enforced at application layer).
model MarketSuspension {
  id          String    @id @default(dbgenerated("uuidv7()")) @db.Uuid
  market      Market
  reason      String // e.g. "ROI -16.3% over 52 bets — auto-suspended"
  triggeredBy String    @default("auto") // "auto" | "manual"
  active      Boolean   @default(true)
  liftedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([market, active])
  @@map("market_suspension")
}

// In-app notifications — persisted for dashboard and future mobile app.
model Notification {
  id        String                 @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  payload   Json? // extra context (market, roi, betCount, etc.)
  read      Boolean                @default(false)
  readAt    DateTime?
  createdAt DateTime               @default(now())
  reads     UserNotificationRead[]

  @@index([read, createdAt])
  @@map("notification")
}

// Per-user read tracking for system-wide notifications.
model UserNotificationRead {
  userId         String       @db.Uuid
  notificationId String
  readAt         DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@id([userId, notificationId])
  @@map("user_notification_read")
}

model NationalTeamEloRating {
  id         String   @id @default(dbgenerated("uuidv7()")) @db.Uuid
  teamName   String
  eloCode    String
  rating     Int
  source     String   @default("eloratings.net")
  snapshotAt DateTime
  syncedAt   DateTime @default(now())

  @@unique([teamName, snapshotAt])
  @@index([snapshotAt])
  @@index([teamName, snapshotAt])
  @@map("national_team_elo_rating")
}

// Odds snapshots — scaffolded for Phase 2 (prematch odds integration).
// Not used in MVP.
model OddsSnapshot {
  id         String             @id @default(dbgenerated("uuidv7()")) @db.Uuid
  fixtureId  String             @db.Uuid
  fixture    Fixture            @relation(fields: [fixtureId], references: [id])
  bookmaker  String
  market     Market
  homeOdds   Decimal?           @db.Decimal(6, 3)
  drawOdds   Decimal?           @db.Decimal(6, 3)
  awayOdds   Decimal?           @db.Decimal(6, 3)
  pick       String? // for non-1X2 markets
  odds       Decimal?           @db.Decimal(6, 3) // for non-1X2 markets
  source     OddsSnapshotSource @default(PREMATCH)
  snapshotAt DateTime
  createdAt  DateTime           @default(now())

  @@index([fixtureId, snapshotAt])
  @@index([fixtureId, bookmaker, market, pick, snapshotAt])
  @@index([snapshotAt])
  @@map("odds_snapshot")
}

// One decision per channel per ModelRun — immutable after creation.
model ChannelDecision {
  id            String                @id @default(dbgenerated("uuidv7()")) @db.Uuid
  modelRunId    String                @db.Uuid
  modelRun      ModelRun              @relation(fields: [modelRunId], references: [id])
  channel       StrategyChannel
  status        ChannelDecisionStatus
  reasonCode    String?
  reasonDetails Json?
  // Config/seuils utilisés par la stratégie pour cette décision (audit, doc §2.4/§4.3)
  configVersion String?
  selections    ChannelSelection[]
  createdAt     DateTime              @default(now())

  @@unique([modelRunId, channel])
  @@index([modelRunId])
  @@index([channel, status, createdAt])
  @@map("channel_decision")
}

// One row per selected pick within a ChannelDecision (usually rank=1 only for v1).
model ChannelSelection {
  id                 String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  channelDecisionId  String          @db.Uuid
  channelDecision    ChannelDecision @relation(fields: [channelDecisionId], references: [id])
  market             Market
  pick               String
  comboMarket        Market?
  comboPick          String?
  probability        Decimal         @db.Decimal(5, 4)
  odds               Decimal?        @db.Decimal(6, 3)
  impliedProbability Decimal?        @db.Decimal(5, 4)
  ev                 Decimal?        @db.Decimal(6, 4)
  qualityScore       Decimal?        @db.Decimal(6, 4)
  rank               Int             @default(1)
  result             BetStatus? // PENDING → WON/LOST/VOID after settlement; Bet.status is financial authority
  settledAt          DateTime?
  bets               Bet[]
  createdAt          DateTime        @default(now())

  // Idempotence du backfill (doc §13) : un rang unique par décision.
  @@unique([channelDecisionId, rank])
  @@index([market, result, createdAt])
  @@map("channel_selection")
}

model Badge {
  id          String      @id @default(cuid())
  code        String      @unique
  name        String
  description String
  iconUrl     String?
  createdAt   DateTime    @default(now())
  users       UserBadge[]

  @@map("badge")
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String   @db.Uuid
  badgeCode  String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
  badge      Badge    @relation(fields: [badgeCode], references: [code])

  @@unique([userId, badgeCode])
  @@map("user_badge")
}

// ─────────────────────────────────────────────
// AI ENGINE — Coupon proposals
// ─────────────────────────────────────────────

model CouponProposal {
  id                     String               @id @default(dbgenerated("uuidv7()")) @db.Uuid
  forDate                DateTime             @db.Date
  signalWindowDays       Int
  targetOddsMin          Decimal              @db.Decimal(6, 2)
  targetOddsMax          Decimal              @db.Decimal(6, 2)
  combinedOdds           Decimal              @db.Decimal(8, 3)
  jointProbability       Decimal              @db.Decimal(5, 4)
  signalScore            Decimal              @db.Decimal(5, 4)
  status                 CouponProposalStatus @default(PENDING)
  result                 CouponResult?
  reasoning              Json?
  rank                   Int                  @default(1) // 1 = meilleur coupon du jour, 2 = second, etc.
  lastFixtureScheduledAt DateTime
  legs                   CouponProposalLeg[]
  generatedAt            DateTime             @default(now())
  updatedAt              DateTime             @updatedAt

  @@unique([forDate, signalWindowDays, targetOddsMin, targetOddsMax, rank])
  @@index([forDate, status])
  @@index([status, lastFixtureScheduledAt])
  @@map("coupon_proposal")
}

model CouponProposalLeg {
  id               String         @id @default(dbgenerated("uuidv7()")) @db.Uuid
  couponProposalId String         @db.Uuid
  couponProposal   CouponProposal @relation(fields: [couponProposalId], references: [id], onDelete: Cascade)
  fixtureId        String         @db.Uuid
  fixture          Fixture        @relation(fields: [fixtureId], references: [id])
  canal            StrategyChannel
  market           Market
  pick             String
  probability      Decimal        @db.Decimal(5, 4)
  oddsSnapshot     Decimal?       @db.Decimal(6, 3)
  signalScore      Decimal        @db.Decimal(5, 4)
  featureSnapshot  Json
  isCorrect        Boolean?
  settledAt        DateTime?
  createdAt        DateTime       @default(now())

  @@index([couponProposalId])
  @@index([fixtureId])
  @@map("coupon_proposal_leg")
}

// ─────────────────────────────────────────────
// ML — Phase 3
// ─────────────────────────────────────────────

model MlModelVersion {
  id           String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  createdAt    DateTime         @default(now())
  // Target segment: "EV:ONE_X_TWO" | "CONF:ONE_X_TWO" | "ALL" etc.
  segment      String
  // "logistic_regression" | "xgboost"
  algorithm    String
  // Feature names used during training
  features     Json
  // { brierScore, calibrationError, roiShadow, sampleSize, trainSize, testSize }
  metrics      Json
  // Path to serialized model on shared Docker volume (ml-models/)
  modelPath    String?
  isActive     Boolean          @default(false)
  activatedAt  DateTime?
  notes        String?
  rollbackOfId String?          @db.Uuid
  rollbackOf   MlModelVersion?  @relation("MlRollback", fields: [rollbackOfId], references: [id])
  rollbacks    MlModelVersion[] @relation("MlRollback")

  @@index([isActive, segment])
  @@index([segment, createdAt])
  @@map("ml_model_version")
}

// ─────────────────────────────────────────────
// EVA — AI chat analyst (Phase 4)
// ─────────────────────────────────────────────

model ChatConversation {
  id        String        @id @default(dbgenerated("uuidv7()")) @db.Uuid
  userId    String        @db.Uuid
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  // Auto-generated from the first question (truncated).
  title     String?
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([userId, updatedAt])
  @@map("chat_conversation")
}

model ChatMessage {
  id             String           @id @default(dbgenerated("uuidv7()")) @db.Uuid
  conversationId String           @db.Uuid
  conversation   ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // 'user' | 'assistant' | 'tool'
  role           String
  content        String
  // Set when role = 'tool'.
  toolName       String?
  // Validated tool-call arguments (audit + replay).
  toolArgs       Json?
  // Structured engine picks shown as cards (role = 'assistant' only).
  picks          Json?
  inputTokens    Int              @default(0)
  outputTokens   Int              @default(0)
  // LLM used (e.g. "llama-4-scout" / "llama-3.1-8b-instant").
  model          String?
  // Prompt system version, for correlating quality regressions.
  promptVersion  String?
  createdAt      DateTime         @default(now())

  @@index([conversationId, createdAt])
  @@map("chat_message")
}

// Per-user daily usage — rate limiting + cost tracking.
model ChatUsage {
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          DateTime @db.Date
  requests     Int      @default(0)
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)

  @@id([userId, day])
  @@map("chat_usage")
}
